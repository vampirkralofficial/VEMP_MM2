--====================================================================
-- SECTION 31: KEYBIND HANDLING
--====================================================================

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Config.Fly.Keybind then
        Config.Fly.Enabled = not Config.Fly.Enabled
        if Config.Fly.Enabled then
            FlySystem.Start(Config.Fly.Speed)
        else
            FlySystem.Stop()
        end
    end
    
    if input.KeyCode == Enum.KeyCode.RightControl then
        local ui = CoreGui:FindFirstChild("Rayfield")
        if ui then
            ui.Enabled = not ui.Enabled
        end
    end
end)

--====================================================================
-- SECTION 32: CHARACTER HANDLING
--====================================================================

local function OnCharacterAdded(character)
    task.wait(1)
    
    local humanoid = character:WaitForChild("Humanoid", 5)
    if not humanoid then return end
    
    if Config.Movement.SpeedEnabled then
        humanoid.WalkSpeed = Config.Movement.WalkSpeed
    end
    if Config.Movement.JumpEnabled then
        if humanoid.UseJumpPower then
            humanoid.JumpPower = Config.Movement.JumpPower
        else
            humanoid.JumpHeight = Config.Movement.JumpPower
        end
    end
    if Config.GodMode then
        humanoid.MaxHealth = math.huge
        task.wait(0.1)
        humanoid.Health = math.huge
    end
    if Config.Movement.Noclip then
        MovementSystem.SetNoclip(true)
    end
    
    -- Update hook method label
    task.wait(0.5)
    if SilentAimSystem.HookInstalled then
        HookMethodLabel:Set("Hook Method: " .. SilentAimSystem.HookMethod)
    end
end

LocalPlayer.CharacterAdded:Connect(OnCharacterAdded)

if LocalPlayer.Character then
    OnCharacterAdded(LocalPlayer.Character)
end

--====================================================================
-- SECTION 33: PERIODIC ROLE UPDATE
--====================================================================

task.spawn(function()
    while true do
        RoleDetector.UpdateRoles()
        task.wait(2)
    end
end)

--====================================================================
-- SECTION 34: INITIALIZATION
--====================================================================

AntiAFKSystem.Start()

local initCharacter = GetCharacter(LocalPlayer)
if initCharacter then
    OnCharacterAdded(initCharacter)
end

Rayfield:LoadConfiguration()

Rayfield:Notify({
    Title = "VEMP MM2 v4.0",
    Content = "Loaded! Platform: " .. (IsMobile and "MOBILE" or "PC") .. " | Silent Aim: Camera Mode (Mobile-Ready) | Press Right Ctrl to toggle UI.",
    Duration = 6,
})

