--====================================================================
-- SECTION 1: SERVICES & CORE REFERENCES
--====================================================================

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")
local Lighting = game:GetService("Lighting")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local ContextActionService = game:GetService("ContextActionService")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera
local Mouse = LocalPlayer:GetMouse()

--====================================================================
-- SECTION 2: MOBILE DETECTION & TOUCH TRACKING
--====================================================================

local IsMobile = false
local TouchPosition = Vector2.new(0, 0)
local LastTapTime = 0
local LastTapPosition = Vector3.new(0, 0, 0)

do
    if UserInputService.TouchEnabled and not UserInputService.MouseEnabled then
        IsMobile = true
    end
    
    local screenSize = Camera.ViewportSize
    if screenSize.X < 800 and UserInputService.TouchEnabled then
        IsMobile = true
    end
end

UserInputService.InputChanged:Connect(function(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.Touch then
        TouchPosition = input.Position
    end
end)

UserInputService.TouchMoved:Connect(function(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.Touch then
        TouchPosition = input.Position
    end
end, false)

UserInputService.TouchTap:Connect(function(touchPositions, processedByUI)
    if not processedByUI then
        LastTapTime = tick()
        if #touchPositions > 0 then
            TouchPosition = touchPositions[1]
        end
    end
end)

local function GetAimPosition()
    if IsMobile then
        if TouchPosition and TouchPosition.X > 0 then
            return TouchPosition
        end
        return Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    else
        local ok, pos = pcall(function()
            return UserInputService:GetMouseLocation()
        end)
        if ok and pos then
            return pos
        end
        return Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    end
end

--====================================================================
-- SECTION 3: EXECUTOR CAPABILITY DETECTION
--====================================================================

local ExecutorInfo = {
    HasHookMetamethod = false,
    HasGetRawMetatable = false,
    HasSetReadOnly = false,
    HasNewCClosure = false,
    HasFireTouchInterest = false,
    HasFireSignal = false,
    HasHookFunction = false,
    HasGetConnections = false,
    HasIdentifyExecutor = false,
    ExecutorName = "Unknown",
}

do
    ExecutorInfo.HasHookMetamethod = pcall(function() return hookmetamethod end)
    ExecutorInfo.HasGetRawMetatable = pcall(function() return getrawmetatable end)
    ExecutorInfo.HasSetReadOnly = pcall(function()
        local t = setmetatable({}, {})
        setreadonly(t, true)
        setreadonly(t, false)
    end)
    ExecutorInfo.HasNewCClosure = pcall(function() return newcclosure end)
    ExecutorInfo.HasFireTouchInterest = pcall(function() return firetouchinterest end)
    ExecutorInfo.HasHookFunction = pcall(function() return hookfunction end)
    ExecutorInfo.HasGetConnections = pcall(function() return getconnections end)
    ExecutorInfo.HasIdentifyExecutor = pcall(function() return identifyexecutor end)
    
    if ExecutorInfo.HasIdentifyExecutor then
        local ok, result = pcall(function() return identifyexecutor() end)
        if ok and type(result) == "string" then
            ExecutorInfo.ExecutorName = result
        end
    end
end

