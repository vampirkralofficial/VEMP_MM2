-- Notification wrapper (safe for WindUI)
local function Notify(title, content, duration)
    SafeCall(function()
        if WindUI and WindUI.Notify then
            WindUI:Notify({
                Title = title,
                Content = content,
                Duration = duration or 5
            })
        end
    end)
end

