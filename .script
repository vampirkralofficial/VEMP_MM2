--====================================================================
-- SECTION 34: KEYBIND HANDLING
--====================================================================

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Config.Fly.Keybind then
        Config.Fly.Enabled = not Config.Fly.Enabled
        if Config.Fly.Enabled then
            FlySystem.Start(Config.Fly.Speed)
        else
            FlySystem.Stop()
        end
    end
    
    if input.KeyCode == Enum.KeyCode.RightControl then
        local ui = CoreGui:FindFirstChild("Rayfield")
        if ui then
            ui.Enabled = not ui.Enabled
        end
    end
end)

--====================================================================
-- SECTION 35: CHARACTER HANDLING
--====================================================================

local function OnCharacterAdded(character)
    task.wait(1)
    local humanoid = character:WaitForChild("Humanoid", 5)
    if not humanoid then return end
    
    if Config.Movement.SpeedEnabled then
        humanoid.WalkSpeed = Config.Movement.WalkSpeed
    end
    if Config.Movement.JumpEnabled then
        if humanoid.UseJumpPower then
            humanoid.JumpPower = Config.Movement.JumpPower
        else
            humanoid.JumpHeight = Config.Movement.JumpPower
        end
    end
    if Config.GodMode then
        humanoid.MaxHealth = math.huge
        task.wait(0.1)
        humanoid.Health = math.huge
    end
    if Config.Movement.Noclip then
        MovementSystem.SetNoclip(true)
    end
end

LocalPlayer.CharacterAdded:Connect(OnCharacterAdded)

if LocalPlayer.Character then
    OnCharacterAdded(LocalPlayer.Character)
end

--====================================================================
-- SECTION 36: PERIODIC ROLE UPDATE
--====================================================================

task.spawn(function()
    while true do
        RoleDetector.UpdateRoles()
        task.wait(2)
    end
end)

--====================================================================
-- SECTION 37: INITIALIZATION
--====================================================================

AntiAFKSystem.Start()

local initCharacter = GetCharacter(LocalPlayer)
if initCharacter then
    OnCharacterAdded(initCharacter)
end

Rayfield:LoadConfiguration()

Rayfield:Notify({
    Title = "VEMP MM2 v4.0",
    Content = "Loaded! Platform: " .. (IsMobile and "MOBILE" or "PC") ..
      " | Use Aimbot for reliable mobile targeting!" ..
      " | Press Right Ctrl to toggle UI.",
    Duration = 8,
})

--====================================================================
-- END OF SCRIPT — VEMP MM2 ULTIMATE EDITION v4.0
--
-- v4.0 FIXES & ADDITIONS:
-- ✓ NEW: Aimbot (camera lock) — works on ALL platforms including mobile
-- ✓ NEW: Triggerbot (auto-fire when target in FOV)
-- ✓ NEW: Sheriff Helper (auto-aim + auto-fire at murderer)
-- ✓ FIXED: Silent Aim universal mode catches ALL FireServer with Vector3
-- ✓ FIXED: Mobile aim position uses screen center (most reliable)
-- ✓ FIXED: GetAimPosition defined only once (no duplicate)
-- ✓ IMPROVED: Multiple hook methods (hookmetamethod → getrawmetatable)
-- ✓ IMPROVED: Multiple fire methods (tool:Activate → mouse1click → VirtualInputManager)
-- ✓ IMPROVED: Shared TargetSystem for all combat features
-- ✓ ADDED: Aimbot smoothness control
-- ✓ ADDED: FOV check for aimbot and triggerbot
-- ✓ KEPT: Optimized auto farm (cached coins, separate thread, no lag)
-- ✓ KEPT: All previous features (ESP, fly, teleport, etc.)
--====================================================================
