--====================================================================
-- SECTION 1: SERVICES & CORE REFERENCES
--====================================================================

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")
local Lighting = game:GetService("Lighting")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")

local LocalPlayer = Players.LocalPlayer
local Camera = Workspace.CurrentCamera
local Mouse = LocalPlayer:GetMouse()

--====================================================================
-- SECTION 2: MOBILE DETECTION
--====================================================================

local IsMobile = false
local TouchPosition = Vector2.new(0, 0)

do
    if UserInputService.TouchEnabled and not UserInputService.MouseEnabled then
        IsMobile = true
    end
    local screenSize = Camera.ViewportSize
    if screenSize.X < 800 and UserInputService.TouchEnabled then
        IsMobile = true
    end
end

UserInputService.InputChanged:Connect(function(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.Touch then
        TouchPosition = input.Position
    end
end)

-- THIS is the key fix: on mobile, always use screen center for aiming
-- because the camera looks forward from center, there's no cursor
local function GetAimPosition()
    if IsMobile then
        return Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    else
        local ok, pos = pcall(function()
            return UserInputService:GetMouseLocation()
        end)
        if ok and pos then
            return pos
        end
        return Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    end
end

--====================================================================
-- SECTION 3: EXECUTOR CAPABILITY DETECTION
--====================================================================

local ExecutorInfo = {
    HasHookMetamethod = false,
    HasGetRawMetatable = false,
    HasSetReadOnly = false,
    HasNewCClosure = false,
    HasFireTouchInterest = false,
    HasMouse1Click = false,
    HasCheckCaller = false,
}

do
    ExecutorInfo.HasHookMetamethod = pcall(function() return hookmetamethod end)
    ExecutorInfo.HasGetRawMetatable = pcall(function() return getrawmetatable end)
    ExecutorInfo.HasSetReadOnly = pcall(function()
        local t = setmetatable({}, {})
        setreadonly(t, true)
        setreadonly(t, false)
    end)
    ExecutorInfo.HasNewCClosure = pcall(function() return newcclosure end)
    ExecutorInfo.HasFireTouchInterest = pcall(function() return firetouchinterest end)
    ExecutorInfo.HasMouse1Click = pcall(function() return mouse1click end)
    ExecutorInfo.HasCheckCaller = pcall(function() return checkcaller end)
end

local function IsExploitCall()
    if ExecutorInfo.HasCheckCaller and checkcaller then
        return checkcaller()
    end
    return false
end

