--====================================================================
-- SECTION 3: UTILITY FUNCTIONS
--====================================================================

local function SafeCall(func, ...)
    local success, err = pcall(func, ...)
    if not success then
        warn("[VEMP MM2] Error: " .. tostring(err))
    end
    return success, err
end

local function WaitForChild(parent, name, timeout)
    timeout = timeout or 5
    local child = parent:FindFirstChild(name)
    if child then return child end
    local start = tick()
    while not child and tick() - start < timeout do
        task.wait(0.1)
        child = parent:FindFirstChild(name)
    end
    return child
end

local function GetCharacter(player)
    if not player then return nil end
    return player.Character
end

local function GetRootPart(player)
    local char = GetCharacter(player)
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
end

local function GetHumanoid(player)
    local char = GetCharacter(player)
    if not char then return nil end
    return char:FindFirstChildOfClass("Humanoid")
end

local function IsAlive(player)
    local humanoid = GetHumanoid(player)
    if not humanoid then return false end
    return humanoid.Health > 0
end

local function GetPlayers()
    local list = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(list, player)
        end
    end
    return list
end

local function GetDistance(from, to)
    if typeof(from) == "Instance" and typeof(to) == "Instance" then
        local fromPos = from:IsA("BasePart") and from.Position or (from:IsA("Model") and from:GetPivot().Position)
        local toPos = to:IsA("BasePart") and to.Position or (to:IsA("Model") and to:GetPivot().Position)
        if fromPos and toPos then
            return (fromPos - toPos).Magnitude
        end
    elseif typeof(from) == "Vector3" and typeof(to) == "Vector3" then
        return (from - to).Magnitude
    end
    return math.huge
end

local function WorldToScreen(worldPosition)
    local screenPosition, onScreen = Camera:WorldToViewportPoint(worldPosition)
    return Vector2.new(screenPosition.X, screenPosition.Y), onScreen
end

local function GetMousePosition()
    return UserInputService:GetMouseLocation()
end

--====================================================================
-- SECTION 4: ROLE DETECTION SYSTEM
--====================================================================

local RoleDetector = {}
RoleDetector.Roles = {}
RoleDetector.KnownMurderer = nil
RoleDetector.KnownSheriff = nil

function RoleDetector.DetectRole(player)
    if not player or not player.Character then return "Unknown" end
    
    local char = player.Character
    local tools = {}
    
    for _, child in ipairs(char:GetChildren()) do
        if child:IsA("Tool") then
            table.insert(tools, child.Name:lower())
        end
    end
    
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        for _, child in ipairs(backpack:GetChildren()) do
            if child:IsA("Tool") then
                table.insert(tools, child.Name:lower())
            end
        end
    end
    
    for _, toolName in ipairs(tools) do
        if toolName:match("knife") or toolName:match("blade") or toolName:match("dagger") then
            return "Murderer"
        elseif toolName:match("gun") or toolName:match("revolver") or toolName:match("pistol") or toolName:match("sheriff") then
            return "Sheriff"
        end
    end
    
    return "Innocent"
end

function RoleDetector.UpdateRoles()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local role = RoleDetector.DetectRole(player)
            RoleDetector.Roles[player] = role
            
            if role == "Murderer" then
                RoleDetector.KnownMurderer = player
            elseif role == "Sheriff" then
                RoleDetector.KnownSheriff = player
            end
        end
    end
end

function RoleDetector.GetRole(player)
    return RoleDetector.Roles[player] or "Unknown"
end

function RoleDetector.GetColor(player)
    local role = RoleDetector.GetRole(player)
    if role == "Murderer" then
        return Config.ESP.MurdererColor
    elseif role == "Sheriff" then
        return Config.ESP.SheriffColor
    elseif role == "Innocent" then
        return Config.ESP.InnocentColor
    end
    return Config.ESP.DefaultColor
end

function RoleDetector.GetLocalRole()
    return RoleDetector.DetectRole(LocalPlayer)
end

--====================================================================
-- SECTION 5: COIN DETECTION SYSTEM
--====================================================================

local CoinSystem = {}
CoinSystem.Coins = {}

function CoinSystem.FindCoins()
    local coins = {}
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local name = obj.Name:lower()
        if name:match("coin") or name:match("cash") or name:match("money") or name:match("pickup") then
            if obj:IsA("BasePart") or obj:IsA("Model") then
                local position
                if obj:IsA("BasePart") then
                    position = obj.Position
                elseif obj:IsA("Model") then
                    position = obj:GetPivot().Position
                end
                
                if position then
                    table.insert(coins, {
                        Object = obj,
                        Position = position,
                        Name = obj.Name,
                    })
                end
            end
        end
    end
    
    CoinSystem.Coins = coins
    return coins
end

function CoinSystem.GetNearestCoin(fromPosition)
    local nearest = nil
    local nearestDistance = math.huge
    
    for _, coin in ipairs(CoinSystem.Coins) do
        if coin.Object and coin.Object.Parent then
            local dist = (fromPosition - coin.Position).Magnitude
            if dist < nearestDistance then
                nearestDistance = dist
                nearest = coin
            end
        end
    end
    
    return nearest, nearestDistance
end

function CoinSystem.CollectCoin(coin)
    if not coin or not coin.Object or not coin.Object.Parent then return false end
    
    local rootPart = GetRootPart(LocalPlayer)
    if not rootPart then return false end
    
    if Config.AutoFarm.CollectMethod == "Teleport" then
        local originalPosition = rootPart.CFrame
        rootPart.CFrame = CFrame.new(coin.Position)
        task.wait(Config.AutoFarm.CoinDelay)
        rootPart.CFrame = originalPosition
    elseif Config.AutoFarm.CollectMethod == "Touch" then
        if coin.Object:IsA("BasePart") then
            firetouchinterest(rootPart, coin.Object, 0)
            task.wait()
            firetouchinterest(rootPart, coin.Object, 1)
        end
    end
    
    return true
end

--====================================================================
-- SECTION 6: ESP SYSTEM (DRAWING API)
--====================================================================

local ESPSystem = {}
ESPSystem.Objects = {}
ESPSystem.Connections = {}
ESPSystem.Enabled = false

function ESPSystem.CreateObjects(player)
    if ESPSystem.Objects[player] then return ESPSystem.Objects[player] end
    
    local objects = {
        Box = Drawing.new("Square"),
        BoxOutline = Drawing.new("Square"),
        Tracer = Drawing.new("Line"),
        Name = Drawing.new("Text"),
        Distance = Drawing.new("Text"),
        HealthBar = Drawing.new("Square"),
        HealthBarOutline = Drawing.new("Square"),
        RoleLabel = Drawing.new("Text"),
    }
    
    objects.Box.Color = Color3.fromRGB(255, 255, 255)
    objects.Box.Thickness = 1
    objects.Box.Filled = false
    objects.Box.Visible = false
    
    objects.BoxOutline.Color = Color3.fromRGB(0, 0, 0)
    objects.BoxOutline.Thickness = 3
    objects.BoxOutline.Filled = false
    objects.BoxOutline.Visible = false
    
    objects.Tracer.Color = Color3.fromRGB(255, 255, 255)
    objects.Tracer.Thickness = 1
    objects.Tracer.Visible = false
    
    objects.Name.Color = Color3.fromRGB(255, 255, 255)
    objects.Name.Size = 13
    objects.Name.Center = true
    objects.Name.Outline = true
    objects.Name.OutlineColor = Color3.fromRGB(0, 0, 0)
    objects.Name.Font = Drawing.Fonts.Plex
    objects.Name.Visible = false
    
    objects.Distance.Color = Color3.fromRGB(200, 200, 200)
    objects.Distance.Size = 13
    objects.Distance.Center = true
    objects.Distance.Outline = true
    objects.Distance.OutlineColor = Color3.fromRGB(0, 0, 0)
    objects.Distance.Font = Drawing.Fonts.Plex
    objects.Distance.Visible = false
    
    objects.HealthBar.Color = Color3.fromRGB(0, 255, 0)
    objects.HealthBar.Thickness = 1
    objects.HealthBar.Filled = true
    objects.HealthBar.Visible = false
    
    objects.HealthBarOutline.Color = Color3.fromRGB(0, 0, 0)
    objects.HealthBarOutline.Thickness = 2
    objects.HealthBarOutline.Filled = true
    objects.HealthBarOutline.Visible = false
    
    objects.RoleLabel.Color = Color3.fromRGB(255, 255, 255)
    objects.RoleLabel.Size = 13
    objects.RoleLabel.Center = true
    objects.RoleLabel.Outline = true
    objects.RoleLabel.OutlineColor = Color3.fromRGB(0, 0, 0)
    objects.RoleLabel.Font = Drawing.Fonts.Plex
    objects.RoleLabel.Visible = false
    
    ESPSystem.Objects[player] = objects
    return objects
end

function ESPSystem.RemoveObjects(player)
    local objects = ESPSystem.Objects[player]
    if not objects then return end
    
    for _, obj in pairs(objects) do
        SafeCall(function()
            obj:Remove()
        end)
    end
    
    ESPSystem.Objects[player] = nil
end

function ESPSystem.UpdatePlayer(player)
    local objects = ESPSystem.CreateObjects(player)
    local character = GetCharacter(player)
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    local head = character and character:FindFirstChild("Head")
    
    if not character or not rootPart or not humanoid or humanoid.Health <= 0 then
        for _, obj in pairs(objects) do
            obj.Visible = false
        end
        return
    end
    
    local localRoot = GetRootPart(LocalPlayer)
    if not localRoot then return end
    
    local distance = (rootPart.Position - localRoot.Position).Magnitude
    if distance > Config.ESP.MaxDistance then
        for _, obj in pairs(objects) do
            obj.Visible = false
        end
        return
    end
    
    local role = RoleDetector.GetRole(player)
    if role == "Innocent" and not Config.ESP.ShowInnocents then
        for _, obj in pairs(objects) do
            obj.Visible = false
        end
        return
    end
    if role == "Sheriff" and not Config.ESP.ShowSheriff then
        for _, obj in pairs(objects) do
            obj.Visible = false
        end
        return
    end
    if role == "Murderer" and not Config.ESP.ShowMurderer then
        for _, obj in pairs(objects) do
            obj.Visible = false
        end
        return
    end
    
    local color = Config.ESP.RoleColorEnabled and RoleDetector.GetColor(player) or Config.ESP.DefaultColor
    
    local headPos, headOnScreen = WorldToScreen(head and head.Position or rootPart.Position)
    local rootPos, rootOnScreen = WorldToScreen(rootPart.Position)
    
    if not headOnScreen and not rootOnScreen then
        for _, obj in pairs(objects) do
            obj.Visible = false
        end
        return
    end
    
    local height = math.abs(rootPos.Y - headPos.Y)
    local width = height * 0.5
    
    local topLeft = Vector2.new(headPos.X - width, headPos.Y)
    local topRight = Vector2.new(headPos.X + width, headPos.Y)
    local bottomLeft = Vector2.new(rootPos.X - width, rootPos.Y)
    local bottomRight = Vector2.new(rootPos.X + width, rootPos.Y)
    
    if Config.ESP.BoxEnabled then
        objects.Box.Size = Vector2.new(width * 2, height)
        objects.Box.Position = Vector2.new(headPos.X - width, headPos.Y)
        objects.Box.Color = color
        objects.Box.Thickness = Config.ESP.BoxThickness
        objects.Box.Transparency = Config.ESP.BoxTransparency
        objects.Box.Visible = true
        
        objects.BoxOutline.Size = Vector2.new(width * 2, height)
        objects.BoxOutline.Position = Vector2.new(headPos.X - width, headPos.Y)
        objects.BoxOutline.Visible = true
    else
        objects.Box.Visible = false
        objects.BoxOutline.Visible = false
    end
    
    if Config.ESP.NameEnabled then
        objects.Name.Text = player.Name
        objects.Name.Position = Vector2.new(headPos.X, headPos.Y - 16)
        objects.Name.Color = color
        objects.Name.Size = Config.ESP.TextSize
        objects.Name.Font = Config.ESP.TextFont
        objects.Name.Visible = true
    else
        objects.Name.Visible = false
    end
    
    if Config.ESP.DistanceEnabled then
        objects.Distance.Text = string.format("[%d]", math.floor(distance))
        objects.Distance.Position = Vector2.new(headPos.X, rootPos.Y + 2)
        objects.Distance.Color = color
        objects.Distance.Size = Config.ESP.TextSize
        objects.Distance.Font = Config.ESP.TextFont
        objects.Distance.Visible = true
    else
        objects.Distance.Visible = false
    end
    
    if Config.ESP.TracerEnabled then
        local mousePos = GetMousePosition()
        local originY = Config.ESP.TracerOrigin == "Bottom" and Camera.ViewportSize.Y or (Config.ESP.TracerOrigin == "Middle" and Camera.ViewportSize.Y / 2 or mousePos.Y)
        local originX = Config.ESP.TracerOrigin == "Bottom" and Camera.ViewportSize.X / 2 or (Config.ESP.TracerOrigin == "Middle" and Camera.ViewportSize.X / 2 or mousePos.X)
        
        objects.Tracer.From = Vector2.new(originX, originY)
        objects.Tracer.To = Vector2.new(rootPos.X, rootPos.Y)
        objects.Tracer.Color = color
        objects.Tracer.Thickness = Config.ESP.TracerThickness
        objects.Tracer.Visible = true
    else
        objects.Tracer.Visible = false
    end
    
    if Config.ESP.HealthBarEnabled and humanoid then
        local healthPercent = math.clamp(humanoid.Health / humanoid.MaxHealth, 0, 1)
        local barHeight = height
        local barWidth = 3
        local barX = headPos.X - width - 8
        
        objects.HealthBarOutline.Size = Vector2.new(barWidth + 2, barHeight + 2)
        objects.HealthBarOutline.Position = Vector2.new(barX - 1, headPos.Y - 1)
        objects.HealthBarOutline.Visible = true
        
        objects.HealthBar.Size = Vector2.new(barWidth, barHeight * healthPercent)
        objects.HealthBar.Position = Vector2.new(barX, rootPos.Y - (barHeight * healthPercent))
        
        if healthPercent > 0.5 then
            objects.HealthBar.Color = Color3.fromRGB(0, 255, 0)
        elseif healthPercent > 0.25 then
            objects.HealthBar.Color = Color3.fromRGB(255, 170, 0)
        else
            objects.HealthBar.Color = Color3.fromRGB(255, 0, 0)
        end
        
        objects.HealthBar.Visible = true
    else
        objects.HealthBar.Visible = false
        objects.HealthBarOutline.Visible = false
    end
    
    objects.RoleLabel.Text = "[" .. role:upper() .. "]"
    objects.RoleLabel.Position = Vector2.new(headPos.X, headPos.Y - 30)
    objects.RoleLabel.Color = color
    objects.RoleLabel.Size = Config.ESP.TextSize
    objects.RoleLabel.Font = Config.ESP.TextFont
    objects.RoleLabel.Visible = Config.ESP.RoleColorEnabled
end

function ESPSystem.UpdateAll()
    for player, _ in pairs(ESPSystem.Objects) do
        if not player.Parent then
            ESPSystem.RemoveObjects(player)
        else
            ESPSystem.UpdatePlayer(player)
        end
    end
end

function ESPSystem.Start()
    if ESPSystem.Enabled then return end
    ESPSystem.Enabled = true
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            ESPSystem.CreateObjects(player)
        end
    end
    
    ESPSystem.Connections.PlayerAdded = Players.PlayerAdded:Connect(function(player)
        task.wait(1)
        ESPSystem.CreateObjects(player)
    end)
    
    ESPSystem.Connections.PlayerRemoving = Players.PlayerRemoving:Connect(function(player)
        ESPSystem.RemoveObjects(player)
    end)
    
    ESPSystem.Connections.RenderStepped = RunService.RenderStepped:Connect(function()
        if Config.ESP.Enabled then
            RoleDetector.UpdateRoles()
            ESPSystem.UpdateAll()
        end
    end)
end

function ESPSystem.Stop()
    ESPSystem.Enabled = false
    for _, conn in pairs(ESPSystem.Connections) do
        SafeCall(function() conn:Disconnect() end)
    end
    ESPSystem.Connections = {}
    
    for player, _ in pairs(ESPSystem.Objects) do
        ESPSystem.RemoveObjects(player)
    end
end

function ESPSystem.SetEnabled(enabled)
    Config.ESP.Enabled = enabled
    if enabled then
        ESPSystem.Start()
    else
        for player, objects in pairs(ESPSystem.Objects) do
            for _, obj in pairs(objects) do
                obj.Visible = false
            end
        end
    end
end

--====================================================================
-- SECTION 7: COIN ESP SYSTEM
--====================================================================

local CoinESPSystem = {}
CoinESPSystem.Objects = {}
CoinESPSystem.Connections = {}
CoinESPSystem.Enabled = false

function CoinESPSystem.Update()
    if not Config.CoinESP.Enabled then
        for _, obj in ipairs(CoinESPSystem.Objects) do
            SafeCall(function() obj:Remove() end)
        end
        CoinESPSystem.Objects = {}
        return
    end
    
    local coins = CoinSystem.FindCoins()
    local localRoot = GetRootPart(LocalPlayer)
    
    for i = #CoinESPSystem.Objects, 1, -1 do
        local obj = CoinESPSystem.Objects[i]
        SafeCall(function() obj:Remove() end)
        table.remove(CoinESPSystem.Objects, i)
    end
    CoinESPSystem.Objects = {}
    
    for _, coin in ipairs(coins) do
        if coin.Object and coin.Object.Parent then
            local coinText = Drawing.new("Text")
            coinText.Text = Config.CoinESP.ShowDistance and localRoot and string.format("Coin [%d]", math.floor((coin.Position - localRoot.Position).Magnitude)) or "Coin"
            coinText.Color = Config.CoinESP.Color
            coinText.Size = Config.CoinESP.Size
            coinText.Center = true
            coinText.Outline = true
            coinText.OutlineColor = Color3.fromRGB(0, 0, 0)
            coinText.Font = Drawing.Fonts.Plex
            
            local screenPos, onScreen = WorldToScreen(coin.Position)
            if onScreen then
                coinText.Position = screenPos
                coinText.Visible = true
            else
                coinText.Visible = false
            end
            
            table.insert(CoinESPSystem.Objects, coinText)
        end
    end
end

function CoinESPSystem.Start()
    if CoinESPSystem.Enabled then return end
    CoinESPSystem.Enabled = true
    
    CoinESPSystem.Connections.RenderStepped = RunService.RenderStepped:Connect(function()
        CoinESPSystem.Update()
    end)
end

function CoinESPSystem.Stop()
    CoinESPSystem.Enabled = false
    for _, conn in pairs(CoinESPSystem.Connections) do
        SafeCall(function() conn:Disconnect() end)
    end
    CoinESPSystem.Connections = {}
    
    for _, obj in ipairs(CoinESPSystem.Objects) do
        SafeCall(function() obj:Remove() end)
    end
    CoinESPSystem.Objects = {}
end

--====================================================================
-- SECTION 8: FOV CIRCLE SYSTEM
--====================================================================

local FOVSystem = {}
FOVSystem.Circle = nil
FOVSystem.Enabled = false

function FOVSystem.Create()
    if FOVSystem.Circle then return FOVSystem.Circle end
    
    FOVSystem.Circle = Drawing.new("Circle")
    FOVSystem.Circle.Radius = Config.SilentAim.FOVRadius
    FOVSystem.Circle.Color = Config.SilentAim.FOVColor
    FOVSystem.Circle.Thickness = Config.SilentAim.FOVThickness
    FOVSystem.Circle.Transparency = Config.SilentAim.FOVTransparency
    FOVSystem.Circle.Filled = Config.SilentAim.FOVFilled
    FOVSystem.Circle.NumSides = 60
    FOVSystem.Circle.Visible = false
    
    return FOVSystem.Circle
end

function FOVSystem.Update()
    if not FOVSystem.Circle then FOVSystem.Create() end
    
    FOVSystem.Circle.Radius = Config.SilentAim.FOVRadius
    FOVSystem.Circle.Color = Config.SilentAim.FOVColor
    FOVSystem.Circle.Thickness = Config.SilentAim.FOVThickness
    FOVSystem.Circle.Transparency = Config.SilentAim.FOVTransparency
    FOVSystem.Circle.Filled = Config.SilentAim.FOVFilled
    FOVSystem.Circle.Position = GetMousePosition()
    FOVSystem.Circle.Visible = Config.SilentAim.FOVEnabled
end

function FOVSystem.SetEnabled(enabled)
    Config.SilentAim.FOVEnabled = enabled
    if enabled and not FOVSystem.Enabled then
        FOVSystem.Enabled = true
        FOVSystem.Create()
        RunService.RenderStepped:Connect(function()
            FOVSystem.Update()
        end)
    end
    if FOVSystem.Circle then
        FOVSystem.Circle.Visible = enabled
    end
end

--====================================================================
-- SECTION 9: SILENT AIM SYSTEM
--====================================================================

local SilentAimSystem = {}
SilentAimSystem.Enabled = false
SilentAimSystem.Target = nil
SilentAimSystem.Connections = {}

function SilentAimSystem.GetClosestPlayerToMouse()
    local closestPlayer = nil
    local shortestDistance = Config.SilentAim.FOVRadius
    local mousePos = GetMousePosition()
    
    for _, player in ipairs(GetPlayers()) do
        if IsAlive(player) and player ~= LocalPlayer then
            local targetPart = GetCharacter(player):FindFirstChild(Config.SilentAim.TargetPart) or GetRootPart(player)
            if targetPart then
                local screenPos, onScreen = WorldToScreen(targetPart.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                    
                    if Config.SilentAim.FOVEnabled then
                        if dist < shortestDistance then
                            if Config.SilentAim.WallCheck then
                                local localRoot = GetRootPart(LocalPlayer)
                                if localRoot then
                                    local rayParams = RaycastParams.new()
                                    rayParams.FilterDescendantsInstances = {LocalPlayer.Character}
                                    rayParams.FilterType = Enum.RaycastFilterType.Exclude
                                    
                                    local rayResult = Workspace:Raycast(localRoot.Position, targetPart.Position - localRoot.Position, rayParams)
                                    if not rayResult or (rayResult.Instance and rayResult.Instance:IsDescendantOf(player.Character)) then
                                        shortestDistance = dist
                                        closestPlayer = player
                                    end
                                end
                            else
                                shortestDistance = dist
                                closestPlayer = player
                            end
                        end
                    else
                        if dist < shortestDistance then
                            shortestDistance = dist
                            closestPlayer = player
                        end
                    end
                end
            end
        end
    end
    
    return closestPlayer
end

function SilentAimSystem.GetClosestPlayer()
    local closestPlayer = nil
    local shortestDistance = math.huge
    local localRoot = GetRootPart(LocalPlayer)
    
    if not localRoot then return nil end
    
    for _, player in ipairs(GetPlayers()) do
        if IsAlive(player) and player ~= LocalPlayer then
            local rootPart = GetRootPart(player)
            if rootPart then
                local dist = (rootPart.Position - localRoot.Position).Magnitude
                if dist < shortestDistance then
                    shortestDistance = dist
                    closestPlayer = player
                end
            end
        end
    end
    
    return closestPlayer
end

function SilentAimSystem.GetTarget()
    if not Config.SilentAim.Enabled then return nil end
    
    local target
    if Config.SilentAim.TargetMode == "ClosestToMouse" then
        target = SilentAimSystem.GetClosestPlayerToMouse()
    elseif Config.SilentAim.TargetMode == "Closest" then
        target = SilentAimSystem.GetClosestPlayer()
    elseif Config.SilentAim.TargetMode == "Murderer" then
        RoleDetector.UpdateRoles()
        if RoleDetector.KnownMurderer and IsAlive(RoleDetector.KnownMurderer) then
            target = RoleDetector.KnownMurderer
        end
    end
    
    SilentAimSystem.Target = target
    return target
end

function SilentAimSystem.GetTargetPosition()
    local target = SilentAimSystem.GetTarget()
    if not target then return nil end
    
    local character = GetCharacter(target)
    if not character then return nil end
    
    local targetPart = character:FindFirstChild(Config.SilentAim.TargetPart) or GetRootPart(target)
    if not targetPart then return nil end
    
    local position = targetPart.Position
    
    if Config.SilentAim.Prediction > 0 then
        local rootPart = GetRootPart(target)
        if rootPart then
            local velocity = rootPart.AssemblyLinearVelocity
            position = position + (velocity * Config.SilentAim.Prediction)
        end
    end
    
    return position
end

local originalNamecall = nil
function SilentAimSystem.HookNamecall()
    if originalNamecall then return end
    
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    
    originalNamecall = mt.__namecall
    
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if Config.SilentAim.Enabled and (method == "FireServer" or method == "fireServer") then
            local name = self and self.Name or ""
            if name:lower():match("gun") or name:lower():match("shoot") or name:lower():match("fire") or name:lower():match("revolver") then
                local hitChance = math.random(1, 100)
                if hitChance <= Config.SilentAim.HitChance then
                    local targetPos = SilentAimSystem.GetTargetPosition()
                    if targetPos then
                        for i = 1, #args do
                            if typeof(args[i]) == "Vector3" then
                                args[i] = targetPos
                                break
                            end
                        end
                        if #args == 0 then
                            table.insert(args, targetPos)
                        end
                    end
                end
            end
        end
        
        return originalNamecall(self, unpack(args))
    end)
    
    setreadonly(mt, true)
end

function SilentAimSystem.UnhookNamecall()
    if not originalNamecall then return end
    
    local mt = getrawmetatable(game)
    setreadonly(mt, false)
    mt.__namecall = originalNamecall
    setreadonly(mt, true)
    
    originalNamecall = nil
end

function SilentAimSystem.SetEnabled(enabled)
    Config.SilentAim.Enabled = enabled
    SilentAimSystem.Enabled = enabled
    if enabled then
        SilentAimSystem.HookNamecall()
    end
end

--====================================================================
-- SECTION 10: KNIFE REACH SYSTEM
--====================================================================

local KnifeReachSystem = {}
KnifeReachSystem.Enabled = false
KnifeReachSystem.Connections = {}
KnifeReachSystem.OriginalHitboxes = {}

function KnifeReachSystem.ExpandHitboxes()
    for _, player in ipairs(GetPlayers()) do
        if IsAlive(player) then
            local character = GetCharacter(player)
            if character then
                for _, part in ipairs(character:GetChildren()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        if not KnifeReachSystem.OriginalHitboxes[part] then
                            KnifeReachSystem.OriginalHitboxes[part] = {
                                Size = part.Size,
                                Transparency = part.Transparency,
                                CanCollide = part.CanCollide,
                            }
                        end
                        part.Size = Vector3.new(Config.Hitbox.Size, Config.Hitbox.Size, Config.Hitbox.Size)
                        part.Transparency = Config.Hitbox.Transparency
                        part.CanCollide = false
                    end
                end
            end
        end
    end
end

function KnifeReachSystem.RestoreHitboxes()
    for part, original in pairs(KnifeReachSystem.OriginalHitboxes) do
        if part and part.Parent then
            SafeCall(function()
                part.Size = original.Size
                part.Transparency = original.Transparency
                part.CanCollide = original.CanCollide
            end)
        end
    end
    KnifeReachSystem.OriginalHitboxes = {}
end

function KnifeReachSystem.AutoKill()
    local localRole = RoleDetector.GetLocalRole()
    if localRole ~= "Murderer" then return end
    
    local localRoot = GetRootPart(LocalPlayer)
    if not localRoot then return end
    
    local knife = nil
    local char = GetCharacter(LocalPlayer)
    if char then
        for _, tool in ipairs(char:GetChildren()) do
            if tool:IsA("Tool") and tool.Name:lower():match("knife") then
                knife = tool
                break
            end
        end
    end
    
    if not knife then return end
    
    for _, player in ipairs(GetPlayers()) do
        if IsAlive(player) then
            local rootPart = GetRootPart(player)
            if rootPart then
                local dist = (rootPart.Position - localRoot.Position).Magnitude
                if dist <= Config.KnifeReach.Reach then
                    SafeCall(function()
                        knife:Activate()
                        if knife:FindFirstChild("Handle") then
                            firetouchinterest(knife.Handle, rootPart, 0)
                            firetouchinterest(knife.Handle, rootPart, 1)
                        end
                    end)
                end
            end
        end
    end
end

function KnifeReachSystem.SetEnabled(enabled)
    Config.KnifeReach.Enabled = enabled
    KnifeReachSystem.Enabled = enabled
    
    if enabled then
        KnifeReachSystem.Connections.RenderStepped = RunService.RenderStepped:Connect(function()
            if Config.KnifeReach.Enabled then
                if Config.KnifeReach.AutoKill then
                    KnifeReachSystem.AutoKill()
                else
                    KnifeReachSystem.ExpandHitboxes()
                end
            end
        end)
    else
        for _, conn in pairs(KnifeReachSystem.Connections) do
            SafeCall(function() conn:Disconnect() end)
        end
        KnifeReachSystem.Connections = {}
        KnifeReachSystem.RestoreHitboxes()
    end
end

--====================================================================
-- SECTION 11: FLY SYSTEM
--====================================================================

local FlySystem = {}
FlySystem.Enabled = false
FlySystem.BodyVelocity = nil
FlySystem.BodyGyro = nil
FlySystem.Connections = {}

function FlySystem.Start(speed)
    local character = GetCharacter(LocalPlayer)
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    FlySystem.Stop()
    
    FlySystem.BodyVelocity = Instance.new("BodyVelocity")
    FlySystem.BodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    FlySystem.BodyVelocity.Velocity = Vector3.new(0, 0, 0)
    FlySystem.BodyVelocity.Parent = rootPart
    
    FlySystem.BodyGyro = Instance.new("BodyGyro")
    FlySystem.BodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    FlySystem.BodyGyro.P = 10000
    FlySystem.BodyGyro.CFrame = rootPart.CFrame
    FlySystem.BodyGyro.Parent = rootPart
    
    FlySystem.Enabled = true
    
    FlySystem.Connections.RenderStepped = RunService.RenderStepped:Connect(function()
        if not FlySystem.Enabled or not rootPart.Parent then
            FlySystem.Stop()
            return
        end
        
        local moveVector = Vector3.new(0, 0, 0)
        local camera = Camera
        
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            moveVector = moveVector + camera.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            moveVector = moveVector - camera.CFrame.LookVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
            moveVector = moveVector - camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
            moveVector = moveVector + camera.CFrame.RightVector
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            moveVector = moveVector + Vector3.new(0, 1, 0)
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then
            moveVector = moveVector - Vector3.new(0, 1, 0)
        end
        
        if moveVector.Magnitude > 0 then
            moveVector = moveVector.Unit * speed
        end
        
        FlySystem.BodyVelocity.Velocity = moveVector
        FlySystem.BodyGyro.CFrame = camera.CFrame
    end)
end

function FlySystem.Stop()
    FlySystem.Enabled = false
    
    for _, conn in pairs(FlySystem.Connections) do
        SafeCall(function() conn:Disconnect() end)
    end
    FlySystem.Connections = {}
    
    if FlySystem.BodyVelocity then
        SafeCall(function() FlySystem.BodyVelocity:Destroy() end)
        FlySystem.BodyVelocity = nil
    end
    if FlySystem.BodyGyro then
        SafeCall(function() FlySystem.BodyGyro:Destroy() end)
        FlySystem.BodyGyro = nil
    end
end

function FlySystem.Toggle(speed)
    if FlySystem.Enabled then
        FlySystem.Stop()
    else
        FlySystem.Start(speed)
    end
    return FlySystem.Enabled
end

--====================================================================
-- SECTION 12: MOVEMENT SYSTEM
--====================================================================

local MovementSystem = {}
MovementSystem.Connections = {}
MovementSystem.OriginalWalkSpeed = 16
MovementSystem.OriginalJumpPower = 50
MovementSystem.NoclipEnabled = false

function MovementSystem.SetWalkSpeed(speed)
    local humanoid = GetHumanoid(LocalPlayer)
    if humanoid then
        if not Config.Movement.SpeedEnabled then
            MovementSystem.OriginalWalkSpeed = humanoid.WalkSpeed
        end
        humanoid.WalkSpeed = speed
        Config.Movement.WalkSpeed = speed
    end
end

function MovementSystem.SetJumpPower(power)
    local humanoid = GetHumanoid(LocalPlayer)
    if humanoid then
        if not Config.Movement.JumpEnabled then
            MovementSystem.OriginalJumpPower = humanoid.JumpPower or humanoid.UseJumpPower and humanoid.JumpPower or humanoid.JumpHeight
        end
        if humanoid.UseJumpPower then
            humanoid.JumpPower = power
        else
            humanoid.JumpHeight = power
        end
        Config.Movement.JumpPower = power
    end
end

function MovementSystem.ResetWalkSpeed()
    local humanoid = GetHumanoid(LocalPlayer)
    if humanoid then
        humanoid.WalkSpeed = MovementSystem.OriginalWalkSpeed
    end
    Config.Movement.SpeedEnabled = false
end

function MovementSystem.ResetJumpPower()
    local humanoid = GetHumanoid(LocalPlayer)
    if humanoid then
        if humanoid.UseJumpPower then
            humanoid.JumpPower = MovementSystem.OriginalJumpPower
        else
            humanoid.JumpHeight = MovementSystem.OriginalJumpPower
        end
    end
    Config.Movement.JumpEnabled = false
end

function MovementSystem.SetNoclip(enabled)
    Config.Movement.Noclip = enabled
    MovementSystem.NoclipEnabled = enabled
    
    if enabled then
        MovementSystem.Connections.Noclip = RunService.Stepped:Connect(function()
            local character = GetCharacter(LocalPlayer)
            if character then
                for _, part in ipairs(character:GetDescendants()) do
                    if part:IsA("BasePart") and part.CanCollide then
                        part.CanCollide = false
                    end
                end
            end
        end)
    else
        if MovementSystem.Connections.Noclip then
            SafeCall(function() MovementSystem.Connections.Noclip:Disconnect() end)
            MovementSystem.Connections.Noclip = nil
        end
    end
end

function MovementSystem.SetInfiniteJump(enabled)
    Config.Movement.InfiniteJump = enabled
    
    if enabled then
        MovementSystem.Connections.JumpRequest = UserInputService.JumpRequest:Connect(function()
            local humanoid = GetHumanoid(LocalPlayer)
            if humanoid then
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end)
    else
        if MovementSystem.Connections.JumpRequest then
            SafeCall(function() MovementSystem.Connections.JumpRequest:Disconnect() end)
            MovementSystem.Connections.JumpRequest = nil
        end
    end
end

--====================================================================
-- SECTION 13: TELEPORT SYSTEM
--====================================================================

local TeleportSystem = {}

function TeleportSystem.ToPosition(position)
    local rootPart = GetRootPart(LocalPlayer)
    if not rootPart then return false end
    Config.Teleport.LastPosition = rootPart.CFrame
    rootPart.CFrame = CFrame.new(position)
    return true
end

function TeleportSystem.ToPlayer(player)
    local targetRoot = GetRootPart(player)
    if not targetRoot then return false end
    return TeleportSystem.ToPosition(targetRoot.Position + Vector3.new(0, 3, 0))
end

function TeleportSystem.ToCFrame(cframe)
    local rootPart = GetRootPart(LocalPlayer)
    if not rootPart then return false end
    Config.Teleport.LastPosition = rootPart.CFrame
    rootPart.CFrame = cframe
    return true
end

function TeleportSystem.ReturnToLastPosition()
    if Config.Teleport.LastPosition then
        return TeleportSystem.ToCFrame(Config.Teleport.LastPosition)
    end
    return false
end

function TeleportSystem.GetSpawnPosition()
    local spawnLocation = Workspace:FindFirstChildOfClass("SpawnLocation")
    if spawnLocation then
        return spawnLocation.Position
    end
    return Vector3.new(0, 50, 0)
end

function TeleportSystem.GetPlayerList()
    local list = {}
    for _, player in ipairs(GetPlayers()) do
        table.insert(list, player.Name)
    end
    return list
end

function TeleportSystem.GetPlayerByName(name)
    for _, player in ipairs(Players:GetPlayers()) do
        if player.Name:lower():match(name:lower()) then
            return player
        end
    end
    return nil
end

function TeleportSystem.TeleportToNearestCoin()
    local rootPart = GetRootPart(LocalPlayer)
    if not rootPart then return false end
    local coins = CoinSystem.FindCoins()
    local nearest, distance = CoinSystem.GetNearestCoin(rootPart.Position)
    if nearest then
        return TeleportSystem.ToPosition(nearest.Position)
    end
    return false
end

--====================================================================
-- SECTION 14: AUTO FARM SYSTEM
--====================================================================

local AutoFarmSystem = {}
AutoFarmSystem.Enabled = false
AutoFarmSystem.Connections = {}

function AutoFarmSystem.Start()
    if AutoFarmSystem.Enabled then return end
    AutoFarmSystem.Enabled = true
    Config.AutoFarm.Enabled = true
    
    task.spawn(function()
        while AutoFarmSystem.Enabled do
            local rootPart = GetRootPart(LocalPlayer)
            if rootPart then
                local coins = CoinSystem.FindCoins()
                local nearest, distance = CoinSystem.GetNearestCoin(rootPart.Position)
                
                if nearest and nearest.Object and nearest.Object.Parent then
                    if Config.AutoFarm.CollectMethod == "Teleport" then
                        local originalCFrame = rootPart.CFrame
                        rootPart.CFrame = CFrame.new(nearest.Position + Vector3.new(0, 3, 0))
                        task.wait(Config.AutoFarm.CoinDelay)
                        if AutoFarmSystem.Enabled and rootPart.Parent then
                            rootPart.CFrame = originalCFrame
                        end
                    elseif Config.AutoFarm.CollectMethod == "Touch" then
                        if nearest.Object:IsA("BasePart") then
                            SafeCall(function()
                                firetouchinterest(rootPart, nearest.Object, 0)
                                task.wait()
                                firetouchinterest(rootPart, nearest.Object, 1)
                            end)
                        end
                    end
                end
            end
            task.wait(Config.AutoFarm.CoinDelay)
        end
    end)
end

function AutoFarmSystem.Stop()
    AutoFarmSystem.Enabled = false
    Config.AutoFarm.Enabled = false
end

function AutoFarmSystem.Toggle()
    if AutoFarmSystem.Enabled then
        AutoFarmSystem.Stop()
    else
        AutoFarmSystem.Start()
    end
    return AutoFarmSystem.Enabled
end

--====================================================================
-- SECTION 15: HITBOX EXPANDER SYSTEM
--====================================================================

local HitboxSystem = {}
HitboxSystem.Enabled = false
HitboxSystem.Connections = {}
HitboxSystem.OriginalSizes = {}

function HitboxSystem.Expand()
    for _, player in ipairs(GetPlayers()) do
        if IsAlive(player) then
            local character = GetCharacter(player)
            if character then
                local hrp = character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    if not HitboxSystem.OriginalSizes[hrp] then
                        HitboxSystem.OriginalSizes[hrp] = hrp.Size
                    end
                    hrp.Size = Vector3.new(Config.Hitbox.Size, Config.Hitbox.Size, Config.Hitbox.Size)
                    hrp.Transparency = Config.Hitbox.Transparency
                    hrp.CanCollide = false
                    hrp.Color = Config.Hitbox.Color
                end
            end
        end
    end
end

function HitboxSystem.Restore()
    for part, originalSize in pairs(HitboxSystem.OriginalSizes) do
        if part and part.Parent then
            SafeCall(function()
                part.Size = originalSize
                part.Transparency = 0
                part.Color = Color3.fromRGB(102, 51, 0)
            end)
        end
    end
    HitboxSystem.OriginalSizes = {}
end

function HitboxSystem.SetEnabled(enabled)
    Config.Hitbox.Enabled = enabled
    HitboxSystem.Enabled = enabled
    
    if enabled then
        HitboxSystem.Connections.RenderStepped = RunService.RenderStepped:Connect(function()
            HitboxSystem.Expand()
        end)
    else
        for _, conn in pairs(HitboxSystem.Connections) do
            SafeCall(function() conn:Disconnect() end)
        end
        HitboxSystem.Connections = {}
        HitboxSystem.Restore()
    end
end

--====================================================================
-- SECTION 16: ANTI-AFK SYSTEM
--====================================================================

local AntiAFKSystem = {}
AntiAFKSystem.Connection = nil

function AntiAFKSystem.Start()
    if AntiAFKSystem.Connection then return end
    
    local virtualUser = game:GetService("VirtualUser")
    AntiAFKSystem.Connection = LocalPlayer.Idled:Connect(function()
        virtualUser:CaptureController()
        virtualUser:ClickButton2(Vector2.new())
    end)
    
    Config.AntiAFK = true
end

function AntiAFKSystem.Stop()
    if AntiAFKSystem.Connection then
        SafeCall(function() AntiAFKSystem.Connection:Disconnect() end)
        AntiAFKSystem.Connection = nil
    end
    Config.AntiAFK = false
end

function AntiAFKSystem.Toggle()
    if Config.AntiAFK then
        AntiAFKSystem.Stop()
    else
        AntiAFKSystem.Start()
    end
    return Config.AntiAFK
end

--====================================================================
-- SECTION 17: MURDERER WARNING SYSTEM
--====================================================================

local MurdererWarningSystem = {}
MurdererWarningSystem.Connections = {}
MurdererWarningSystem.Enabled = false
MurdererWarningSystem.LastWarning = 0

function MurdererWarningSystem.Start()
    if MurdererWarningSystem.Enabled then return end
    MurdererWarningSystem.Enabled = true
    Config.MurdererWarning = true
    
    MurdererWarningSystem.Connections.RenderStepped = RunService.Heartbeat:Connect(function()
        if not Config.MurdererWarning then return end
        
        RoleDetector.UpdateRoles()
        local murderer = RoleDetector.KnownMurderer
        
        if murderer and IsAlive(mururderer) and murderer ~= LocalPlayer then
            local localRoot = GetRootPart(LocalPlayer)
            local murdererRoot = GetRootPart(murderer)
            
            if localRoot and murdererRoot then
                local distance = (localRoot.Position - murdererRoot.Position).Magnitude
                
                if distance < 50 and tick() - MurdererWarningSystem.LastWarning > 5 then
                    MurdererWarningSystem.LastWarning = tick()
                end
            end
        end
    end)
end

function MurdererWarningSystem.Stop()
    MurdererWarningSystem.Enabled = false
    for _, conn in pairs(MurdererWarningSystem.Connections) do
        SafeCall(function() conn:Disconnect() end)
    end
    MurdererWarningSystem.Connections = {}
end

--====================================================================
-- SECTION 18: WALK ON WALLS SYSTEM
--====================================================================

local WalkOnWallsSystem = {}
WalkOnWallsSystem.Enabled = false
WalkOnWallsSystem.Connections = {}

function WalkOnWallsSystem.SetEnabled(enabled)
    Config.WalkOnWalls = enabled
    WalkOnWallsSystem.Enabled = enabled
    
    if enabled then
        WalkOnWallsSystem.Connections.RenderStepped = RunService.RenderStepped:Connect(function()
            local character = GetCharacter(LocalPlayer)
            local humanoid = character and character:FindFirstChildOfClass("Humanoid")
            
            if humanoid then
                local state = humanoid:GetState()
                if state == Enum.HumanoidStateType.Freefall then
                    local rayParams = RaycastParams.new()
                    rayParams.FilterDescendantsInstances = {character}
                    rayParams.FilterType = Enum.RaycastFilterType.Exclude
                    
                    local rootPart = GetRootPart(LocalPlayer)
                    if rootPart then
                        local rayResult = Workspace:Raycast(rootPart.Position, Vector3.new(0, -5, 0), rayParams)
                        if rayResult and rayResult.Normal then
                            rootPart.CFrame = CFrame.new(rootPart.Position, rootPart.Position - rayResult.Normal)
                        end
                    end
                end
            end
        end)
    else
        for _, conn in pairs(WalkOnWallsSystem.Connections) do
            SafeCall(function() conn:Disconnect() end)
        end
        WalkOnWallsSystem.Connections = {}
    end
end

--====================================================================
-- SECTION 19: GOD MODE SYSTEM
--====================================================================

local GodModeSystem = {}
GodModeSystem.Connections = {}
GodModeSystem.Enabled = false

function GodModeSystem.SetEnabled(enabled)
    Config.GodMode = enabled
    GodModeSystem.Enabled = enabled
    
    if enabled then
        GodModeSystem.Connections.CharacterAdded = LocalPlayer.CharacterAdded:Connect(function(char)
            task.wait(0.5)
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid.MaxHealth = math.huge
                humanoid.Health = math.huge
            end
        end)
        
        local char = GetCharacter(LocalPlayer)
        if char then
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid.MaxHealth = math.huge
                humanoid.Health = math.huge
            end
        end
        
        GodModeSystem.Connections.Heartbeat = RunService.Heartbeat:Connect(function()
            local humanoid = GetHumanoid(LocalPlayer)
            if humanoid and humanoid.Health < humanoid.MaxHealth then
                humanoid.Health = humanoid.MaxHealth
            end
        end)
    else
        for _, conn in pairs(GodModeSystem.Connections) do
            SafeCall(function() conn:Disconnect() end)
        end
        GodModeSystem.Connections = {}
        
        local char = GetCharacter(LocalPlayer)
        if char then
            local humanoid = char:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid.MaxHealth = 100
                humanoid.Health = 100
            end
        end
    end
end

--====================================================================
-- SECTION 20: CUSTOM CROSSHAIR SYSTEM
--====================================================================

local CrosshairSystem = {}
CrosshairSystem.Lines = {}
CrosshairSystem.Enabled = false
CrosshairSystem.Connections = {}

function CrosshairSystem.Create()
    CrosshairSystem.Lines = {}
    
    local top = Drawing.new("Line")
    top.Color = Color3.fromRGB(0, 255, 0)
    top.Thickness = 1
    table.insert(CrosshairSystem.Lines, top)
    
    local bottom = Drawing.new("Line")
    bottom.Color = Color3.fromRGB(0, 255, 0)
    bottom.Thickness = 1
    table.insert(CrosshairSystem.Lines, bottom)
    
    local left = Drawing.new("Line")
    left.Color = Color3.fromRGB(0, 255, 0)
    left.Thickness = 1
    table.insert(CrosshairSystem.Lines, left)
    
    local right = Drawing.new("Line")
    right.Color = Color3.fromRGB(0, 255, 0)
    right.Thickness = 1
    table.insert(CrosshairSystem.Lines, right)
    
    local center = Drawing.new("Square")
    center.Color = Color3.fromRGB(255, 0, 0)
    center.Size = Vector2.new(2, 2)
    center.Filled = true
    center.Transparency = 1
    table.insert(CrosshairSystem.Lines, center)
end

function CrosshairSystem.Update()
    local mousePos = GetMousePosition()
    local gap = 5
    local length = 10
    
    if #CrosshairSystem.Lines == 0 then
        CrosshairSystem.Create()
    end
    
    CrosshairSystem.Lines[1].From = Vector2.new(mousePos.X, mousePos.Y - gap - length)
    CrosshairSystem.Lines[1].To = Vector2.new(mousePos.X, mousePos.Y - gap)
    CrosshairSystem.Lines[1].Visible = Config.CustomCrosshair
    
    CrosshairSystem.Lines[2].From = Vector2.new(mousePos.X, mousePos.Y + gap)
    CrosshairSystem.Lines[2].To = Vector2.new(mousePos.X, mousePos.Y + gap + length)
    CrosshairSystem.Lines[2].Visible = Config.CustomCrosshair
    
    CrosshairSystem.Lines[3].From = Vector2.new(mousePos.X - gap - length, mousePos.Y)
    CrosshairSystem.Lines[3].To = Vector2.new(mousePos.X - gap, mousePos.Y)
    CrosshairSystem.Lines[3].Visible = Config.CustomCrosshair
    
    CrosshairSystem.Lines[4].From = Vector2.new(mousePos.X + gap, mousePos.Y)
    CrosshairSystem.Lines[4].To = Vector2.new(mousePos.X + gap + length, mousePos.Y)
    CrosshairSystem.Lines[4].Visible = Config.CustomCrosshair
    
    CrosshairSystem.Lines[5].Position = mousePos
    CrosshairSystem.Lines[5].Visible = Config.CustomCrosshair
end

function CrosshairSystem.SetEnabled(enabled)
    Config.CustomCrosshair = enabled
    CrosshairSystem.Enabled = enabled
    
    if enabled then
        if #CrosshairSystem.Lines == 0 then
            CrosshairSystem.Create()
        end
        CrosshairSystem.Connections.RenderStepped = RunService.RenderStepped:Connect(function()
            CrosshairSystem.Update()
        end)
    else
        for _, conn in pairs(CrosshairSystem.Connections) do
            SafeCall(function() conn:Disconnect() end)
        end
        CrosshairSystem.Connections = {}
        
        for _, line in ipairs(CrosshairSystem.Lines) do
            SafeCall(function() line.Visible = false end)
        end
    end
end

